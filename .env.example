# Copy to .env for local development. Never commit a real .env.

# Postgres DSN. Required. No default.
# Matches docker-compose.yml postgres service.
DATABASE_URL=postgres://ottawa:ottawa@postgres:5432/ottawa_waittimes?sslmode=disable

# API listen port. Default: 8080.
API_PORT=8080

# How often the scraper hits each hospital, in seconds. Default: 900 (15 min).
SCRAPE_INTERVAL_SECONDS=900

# Minimum seconds between requests to the same hostname. Default: 30.
RATE_LIMIT_PER_DOMAIN_SECONDS=30

# slog level: debug | info | warn | error. Default: info.
LOG_LEVEL=info
